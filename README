-- ============================================================
-- REPOSITORIOS
-- ============================================================
--
--  в”Ңв”Җ SupaBaseSQLEditor  (este repo)
--  в”Ӯ    Esquema SQL completo: tablas, RLS, triggers, Гӯndices.
--  в”Ӯ    Se ejecuta en el SQL Editor de Supabase o via psql.
--  в”Ӯ    Archivos:
--  в”Ӯ      000_DROP_ALL.sql           Limpia tablas Y funciones
--  в”Ӯ      001_TABLAS.sql             DDL de todas las tablas
--  в”Ӯ      002_RLS.sql                Seguridad a nivel de fila
--  в”Ӯ      003_FUNCIONES_TRIGGERS.sql LГіgica de negocio en BD
--  в”Ӯ      004_INDICES.sql            ГҚndices de rendimiento
--  в”Ӯ      005_USUARIOS.sql           CreaciГіn de usuarios demo
--  в”Ӯ      006_MULTI_TENANT_UNIQUE.sql  UNIQUE (contrato_id, folio/id_unico)
--  в”Ӯ      007_ADMIN_DELETE_POLICES.sql PolГӯticas DELETE para rol admin
--  в”Ӯ
--  в””в”Җ BDO-IDU-1556-2025  (repo de sincronizaciГіn)
--       Scripts Python que conectan QFieldCloud con Supabase.
--       Se ejecutan manualmente o vГӯa GitHub Actions.
--       Carpetas:
--         sync/                      MГіdulos Python de sync
--         migrations/                Parches SQL incrementales
--         .github/workflows/         Workflow de automatizaciГіn
--
-- ============================================================
-- MГ“DULOS SQL (este repo)
-- ============================================================
--
-- 001_TABLAS.sql
-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--   Define todas las tablas del dominio en snake_case.
--   Orden de creaciГіn respeta las dependencias FK:
--
--   perfiles
--   contratos
--     в””в”Җв–¶ contratos_prorrogas        вҶҗ seguimiento de prГіrrogas
--     в””в”Җв–¶ contratos_adiciones        вҶҗ seguimiento de adiciones
--     в””в”Җв–¶ localidades
--     в””в”Җв–¶ tramos_aux_infra
--     в””в”Җв–¶ tramos_aux_tramos
--     в””в”Җв–¶ tramos_bd
--     в””в”Җв–¶ presupuesto_aux_actividad
--         в””в”Җв–¶ presupuesto_aux_capitulos
--         в””в”Җв–¶ presupuesto_bd
--     в””в”Җв–¶ presupuesto_componentes_bd
--     в””в”Җв–¶ presupuesto_componentes_aux
--     в””в”Җв–¶ registros_cantidades          вҶҗ formulario principal
--     в””в”Җв–¶ registros_componentes         вҶҗ formulario principal
--     в””в”Җв–¶ registros_reporte_diario      вҶҗ formulario principal
--         в””в”Җв–¶ bd_personal_obra
--         в””в”Җв–¶ bd_condicion_climatica
--         в””в”Җв–¶ bd_maquinaria_obra
--         в””в”Җв–¶ bd_sst_ambiental
--     в””в”Җв–¶ rf_cantidades                 вҶҗ fotos (sin FK por diseГұo)
--     в””в”Җв–¶ rf_componentes                вҶҗ fotos (sin FK por diseГұo)
--     в””в”Җв–¶ rf_reporte_diario             вҶҗ fotos (sin FK por diseГұo)
--     в””в”Җв–¶ formulario_pmt
--     в””в”Җв–¶ historial_estados             вҶҗ auditorГӯa (sin FK por diseГұo)
--     в””в”Җв–¶ cierres_semanales
--         в””в”Җв–¶ cierre_registros
--     в””в”Җв–¶ notificaciones                вҶҗ genГ©rico (sin FK por diseГұo)
--     в””в”Җв–¶ sync_state                   вҶҗ estado de sync incremental
--
--   001_TABLAS.sql tambiГ©n incluye:
--   В· Seed data de contratos_aux_infra (EP, CI, MV)
--   В· presupuesto_aux_actividad (MANTENIMIENTO, REHABILITACIONвҖҰ)
--   В· INSERT del contrato IDU-1556-2025 con datos del Excel BD_CTO_INI
--   В· Bloques DO idempotentes de migraciГіn (PATCH-001/002)
--   В· Triggers de sincronizaciГіn contractual (secciГіn 10):
--       trg_sync_prorrogas вҶ’ actualiza contratos.prorrogas y
--                            contratos.plazo_actual
--       trg_sync_adiciones вҶ’ actualiza contratos.adiciones y
--                            contratos.valor_actual
--
-- 002_RLS.sql
-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--   Row Level Security habilitado en TODAS las tablas.
--   Cada perfil solo puede leer/escribir segГәn su rol.
--   Usa la funciГіn helper get_rol() para evaluar el rol del
--   usuario autenticado.
--
--   Tablas con RLS y sus polГӯticas:
--     perfiles               вҶ’ cada usuario ve su propio perfil;
--                              admin gestiona todos
--     contratos              вҶ’ lectura: todos; escritura: admin/service
--     contratos_prorrogas    вҶ’ lectura: todos; escritura: admin/service
--     contratos_adiciones    вҶ’ lectura: todos; escritura: admin/service
--     registros_cantidades   вҶ’ inspector crea/edita sus borradores;
--                              residente aprueba (nivel 1);
--                              interventor aprueba (nivel 2);
--                              admin acceso total
--     registros_componentes  вҶ’ misma lГіgica que registros_cantidades
--     registros_reporte_diario вҶ’ misma lГіgica
--     formulario_pmt         вҶ’ inspector crea; roles superiores leen
--     historial_estados      вҶ’ rol вүҘ residente lee; roles escriben
--     cierres_semanales      вҶ’ rol вүҘ residente lee; interventor/admin crea
--     notificaciones         вҶ’ cada usuario ve las propias
--     localidades            вҶ’ solo lectura (service_role escribe)
--     tramos_aux_infra       вҶ’ solo lectura (service_role escribe)
--     tramos_aux_tramos      вҶ’ solo lectura (service_role escribe)
--     tramos_bd              вҶ’ solo lectura (service_role escribe)
--     presupuesto_aux_*      вҶ’ solo lectura (service_role escribe)
--     presupuesto_bd         вҶ’ solo lectura (service_role escribe)
--     presupuesto_componentes_bd  вҶ’ solo lectura (service_role escribe)
--     presupuesto_componentes_aux вҶ’ solo lectura (service_role escribe)
--     rf_cantidades          вҶ’ lectura todos; escritura service_role
--     rf_componentes         вҶ’ lectura todos; escritura service_role
--     rf_reporte_diario      вҶ’ lectura todos; escritura service_role
--     bd_personal_obra       вҶ’ lectura todos; escritura service_role
--     bd_condicion_climatica вҶ’ lectura todos; escritura service_role
--     bd_maquinaria_obra     вҶ’ lectura todos; escritura service_role
--     bd_sst_ambiental       вҶ’ lectura todos; escritura service_role
--
-- 003_FUNCIONES_TRIGGERS.sql
-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--   LГіgica de negocio ejecutada automГЎticamente en la BD:
--
--   В· marcar_inmutable()    вҶ’ BEFORE UPDATE: cuando estado вҶ’ 'APROBADO'
--                             marca el registro inmutable y estampa
--                             fecha_interventor. Impide modificaciones
--                             posteriores.
--
--   В· log_cambio_estado()   вҶ’ AFTER UPDATE: registra en historial_estados
--                             cada cambio de estado con tabla_origen,
--                             usuario y observaciГіn.
--
--   В· crear_notificacion()  вҶ’ AFTER INSERT OR UPDATE: genera entradas
--                             en notificaciones para todos los usuarios
--                             activos del contrato.
--
--   Los tres triggers se instalan sobre las tres tablas de formularios:
--   registros_cantidades, registros_componentes, registros_reporte_diario.
--
--   Nota: los triggers de sincronizaciГіn contractual
--   (trg_sync_prorrogas, trg_sync_adiciones) estГЎn en 001_TABLAS.sql
--   junto a la DDL de las tablas que los originan.
--
-- 004_INDICES.sql
-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--   ГҚndices sobre columnas de consulta frecuente.
--   Tablas cubiertas:
--     registros_cantidades    (folio, estado, contrato_id,
--                              contrato+estado, id_tramo, fecha, inspector,
--                              item_pago)
--     registros_componentes   (mismas columnas)
--     registros_reporte_diario (folio, estado, contrato_id,
--                               contrato+estado, fecha, inspector)
--     historial_estados       (registro_id, tabla_origen, cambiado_por)
--     cierres_semanales       (contrato_id, semana)
--     notificaciones          (destinatario, enviado=FALSE parcial)
--     contratos_prorrogas     (contrato_id, contrato+numero, fecha_firma)
--     contratos_adiciones     (contrato_id, contrato+numero, fecha_firma)
--     formulario_pmt          (folio, contrato_id, vigencia)
--     bd_personal_obra        (folio)
--     bd_condicion_climatica  (folio)
--     bd_maquinaria_obra      (folio)
--     bd_sst_ambiental        (folio)
--     rf_cantidades           (folio)
--     rf_componentes          (folio)
--     rf_reporte_diario       (folio)
--
-- 005_USUARIOS.sql
-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--   Script utilitario para crear perfiles de usuario.
--   PASO 1: crear el usuario en Supabase Auth вҶ’ copiar UUID.
--   PASO 2: insertar en perfiles con ese UUID.
--   Solo para entornos de desarrollo / usuarios iniciales.
--
-- 006_MULTI_TENANT_UNIQUE.sql
-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--   Constraints UNIQUE compuestos por contrato en todas las tablas
--   de formularios y registros fotogrГЎficos.
--   Formularios вҶ’ UNIQUE (contrato_id, folio):
--     registros_cantidades В· registros_componentes
--     registros_reporte_diario В· formulario_pmt
--   Fotos вҶ’ UNIQUE (contrato_id, id_unico):
--     rf_cantidades В· rf_componentes В· rf_reporte_diario
--
-- 007_ADMIN_DELETE_POLICES.sql
-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--   PolГӯticas RLS que permiten al rol admin eliminar registros en:
--     anotaciones_generales В· correspondencia
--     registros_reporte_diario В· registros_cantidades
--     registros_componentes
--
-- ============================================================
-- MГ“DULOS PYTHON DE SINCRONIZACIГ“N (BDO-IDU-1556-2025/sync/)
-- ============================================================
--
--   sync_qfield.py        Orquestador: ejecuta todos los mГіdulos
--                         en el orden correcto de dependencias.
--   config.py             Variables de entorno (SUPABASE_URL,
--                         QFIELD_USER, QFIELD_PASSWORDвҖҰ).
--   connections.py        Login QFieldCloud + cliente Supabase.
--   gpkg.py               download_file() genГ©rico (GPKG y XLSX);
--                         download_gpkg() alias; read_layer();
--                         delete_all().
--   photos.py             Descarga fotos de QFieldCloud, las comprime
--                         con Pillow (mГЎx 2048px, JPEG quality=82,
--                         sin EXIF) y las sube al bucket Registro_Obra.
--                         Devuelve URL pГәblica para uso en Streamlit.
--   utils.py              safe(), safe_num(), coords_from_geom().
--   sync_contrato.py      Contrato: descarga Contrato_IDU_1556_2025.xlsx
--                         una vez y sincroniza:
--                           BD_CTO_INI вҶ’ contratos
--                           BD_CTO_PRO вҶ’ contratos_prorrogas
--                           BD_CTO_ADI вҶ’ contratos_adiciones
--   sync_lookup.py        Tablas catГЎlogo:
--                           tramos_aux_infra       (BDTRAMOS.gpkg)
--                           tramos_aux_tramos      (AUXTRAMOS.gpkg)
--                           presupuesto_aux_actividad (BDPRESUPUESTO.gpkg)
--                           presupuesto_aux_capitulos (AUXCAPITULOS.gpkg)
--   sync_geo.py           Referencia geogrГЎfica:
--                           localidades (loca.gpkg)
--                           tramos_bd   (BDTRAMOS.gpkg)
--   sync_presupuesto.py   Presupuesto:
--                           presupuesto_bd             (BDPRESUPUESTO.gpkg)
--                           presupuesto_componentes_bd  (Presupuesto_Componentes.gpkg)
--                           presupuesto_componentes_aux (aux_pptcomponentes.gpkg)
--   sync_formularios.py   Formularios principales:
--                           registros_cantidades      (Formulario_Cantidades.gpkg)
--                           registros_componentes     (Reporte_Componentes.gpkg)
--                           registros_reporte_diario  (Reporte_Diario.gpkg)
--                           formulario_pmt            (Formulario_PMT.gpkg)
--   sync_bd.py            Tablas secundarias del reporte diario:
--                           bd_personal_obra         (BD_PersonalObra.gpkg)
--                           bd_condicion_climatica   (BD_CondicionClimatica.gpkg)
--                           bd_maquinaria_obra       (BD_MaquinariaObra.gpkg)
--                           bd_sst_ambiental         (BD_SST-Ambiental.gpkg)
--   sync_rf.py            Registros fotogrГЎficos:
--                           rf_cantidades      (RF_Cantidades.gpkg)
--                           rf_componentes     (RF_Componentes.gpkg)
--                           rf_reporte_diario  (RF_ReporteDiario.gpkg)
--
--   Orden de ejecuciГіn en sync_qfield.py:
--     0. Contrato          (contratos, prorrogas, adiciones)  вҶҗ PRIMERO
--                           otras tablas referencian contratos.id
--     1. Tablas catГЎlogo   (tramos_aux_infra, tramos_aux_tramos,
--                           presupuesto_aux_actividad, presupuesto_aux_capitulos)
--     2. Referencia geo    (localidades, tramos_bd)
--     3. Presupuesto       (presupuesto_bd, componentes_bd, componentes_aux)
--     4. Formularios       (cantidades, componentes, reporte_diario, pmt)
--     5. Tablas secundarias (personal, climatica, maquinaria, sst)
--     6. Fotos             (rf_cantidades, rf_componentes, rf_reporte_diario)
--
--   El orden no es arbitrario:
--   В· contratos debe existir antes que cualquier tabla que lo referencia.
--   В· Las tablas secundarias (paso 5) tienen FK a reporte_diario.folio
--     вҶ’ deben existir esos registros antes de insertar.
--   В· Las fotos (paso 6) se procesan al final: son la operaciГіn mГЎs lenta
--     (descarga + compresiГіn + subida a Storage por cada registro).
--
-- ============================================================
-- DECISIONES DE DISEГ‘O RELEVANTES
-- ============================================================
--
--  В· folio vs id_unico
--    folio     = identificador de formulario (un inspector puede
--                generar varios Гӯtems en el mismo formulario).
--    id_unico  = identificador de fila dentro del GPKG.
--    registros_cantidades tiene mГәltiples filas con el mismo folio
--    (una por Гӯtem de pago). El sync hace upsert por id_unico,
--    no por folio.
--
--  В· FK deliberadamente ausentes en columnas de sync
--    id_tramo, codigo_elemento, tipo_infra y tipo_actividad en
--    registros_* son TEXT sin REFERENCES. Motivo: el sync puede
--    insertar formularios antes de que las tablas de referencia
--    estГ©n completamente sincronizadas, lo que causarГӯa error 23503.
--    La integridad se garantiza por el orden de sync, no por FK.
--
--  В· rf_* sin FK en id_unico
--    id_unico en rf_cantidades/componentes/reporte_diario es el
--    identificador propio de la foto, no una referencia al
--    formulario padre. La relaciГіn fotoвҶ”formulario se navega
--    por folio. Agregar FK causaba error 23503 en producciГіn.
--
--  В· historial_estados y notificaciones sin FK en registro_id
--    Estas tablas registran eventos de las tres tablas de
--    formularios. Una FK a una sola tabla harГӯa imposible auditar
--    las otras dos. Se usa tabla_origen TEXT con CHECK para
--    identificar la tabla de procedencia.
--
--  В· foto_url en rf_*
--    Cada foto se sube al bucket 'Registro_Obra' de Supabase Storage
--    durante el sync, comprimida a JPEG quality=82 / mГЎx 2048px.
--    La URL pГәblica queda en foto_url y puede usarse directamente
--    en Streamlit con st.image(url).
--
--  В· prorrogas / adiciones mantenidos por trigger
--    Los campos contratos.prorrogas, contratos.plazo_actual,
--    contratos.adiciones y contratos.valor_actual NO se escriben
--    directamente desde el sync_contrato.py. Los actualiza
--    automГЎticamente el trigger trg_sync_prorrogas /
--    trg_sync_adiciones cada vez que se inserta, modifica o
--    elimina una fila en contratos_prorrogas / contratos_adiciones.
--
--  В· intrventoria (typo en el Excel)
--    La columna se llama 'intrventoria' (con typo) en el Excel
--    Contrato_IDU_1556_2025.xlsx hoja BD_CTO_INI y en la BD.
--    Se mantiene el nombre para garantizar la compatibilidad
--    exacta con el archivo fuente. El cГіdigo de sync acepta
--    tanto 'intrventoria' como 'interventoria' para tolerancia.
--
-- ============================================================
-- INICIALIZACIГ“N DEL ESQUEMA
-- ============================================================
--
--   Para crear el esquema desde cero (entorno nuevo o reset):
--
--     1. Ejecutar 000_DROP_ALL.sql            (elimina tablas Y funciones)
--     2. Ejecutar 001_TABLAS.sql              (crea tablas + seed data + sync_state)
--     3. Ejecutar 002_RLS.sql                 (polГӯticas de seguridad)
--     4. Ejecutar 003_FUNCIONES_TRIGGERS.sql
--     5. Ejecutar 004_INDICES.sql
--     6. Ejecutar 005_USUARIOS.sql            (solo en desarrollo)
--     7. Ejecutar 006_MULTI_TENANT_UNIQUE.sql (constraints UNIQUE multi-tenant)
--     8. Ejecutar 007_ADMIN_DELETE_POLICES.sql (DELETE para admin)
--
--   IMPORTANTE: 000_DROP_ALL.sql tambiГ©n elimina las funciones
--   (get_rol, marcar_inmutable, log_cambio_estado, crear_notificacion,
--   sync_contrato_*). Si solo se quiere resetear datos sin recrear
--   el esquema, NO ejecutar 000.
--
-- ============================================================
-- EJECUCIГ“N LOCAL DEL SYNC (pruebas)
-- ============================================================
--
--   Requisitos:
